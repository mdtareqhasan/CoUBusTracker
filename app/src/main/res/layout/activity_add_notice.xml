<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/white"
    android:clipToPadding="false">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post New Notice"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/noticeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notice Title"
            android:background="@drawable/edittext_underline"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/black"
            android:minHeight="48dp"
            android:layout_marginBottom="12dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <EditText
            android:id="@+id/noticeBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Notice Body"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:gravity="top|start"
            android:background="@drawable/edittext_underline"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/black"
            android:layout_marginBottom="1dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <EditText
            android:id="@+id/noticeExpiry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Expiry Time (in hours)"
            android:inputType="number"
            android:minHeight="48dp"
            android:background="@drawable/edittext_underline"
            android:textColorHint="@color/hint_gray"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <Button
            android:id="@+id/postNoticeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Post Notice"
            android:textColor="@color/white"
            android:backgroundTint="@color/popularblue2"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Current Notices:"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp"
            android:paddingStart="4dp" />

        <LinearLayout
            android:id="@+id/noticeListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
