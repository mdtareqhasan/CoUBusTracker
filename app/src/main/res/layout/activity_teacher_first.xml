<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bgg21"
    android:paddingTop="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="40dp"
        android:padding="20dp">


        <!-- Teachers' Bus Section -->
        <Button
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="\nTeacher Bus List:\n"
            android:backgroundTint="@color/stndgreen"
            android:layout_marginBottom="10dp"
            android:textColor="@color/white"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:columnCount="2">

            <Button
                android:id="@+id/teacherBus1"
                style="@style/TeacherBusButton"
                android:tag="teacher1"
                android:text="Bus: 1"
                android:onClick="openLogin"/>

            <Button
                android:id="@+id/teacherBus2"
                style="@style/TeacherBusButton"
                android:tag="teacher2"
                android:text="Bus: 2"
                android:onClick="openLogin"/>
        </GridLayout>

        <!-- Officers' Bus Section -->
        <Button
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:text="\nOfficer Bus List\n"
            android:backgroundTint="@color/darkblue"
            android:layout_marginBottom="10dp"
            android:textColor="@color/white"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            android:columnCount="2">

            <Button
                android:id="@+id/officerBus1"
                style="@style/BlueBusButton"
                android:tag="officer1"
                android:text="Bus: 1"
                android:onClick="openLogin"/>

            <Button
                android:id="@+id/officerBus2"
                style="@style/BlueBusButton"
                android:text="extra"
                android:onClick="openLogin"/>
        </GridLayout>


        <!-- Bus Schedule Button -->
        <Button
            android:id="@+id/busScheduleButton"
            style="@style/BusSceduleButton"
            android:tag="busscedule2"
            android:onClick="openLogin"
            android:text="Bus Schedule" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n\n"
            android:importantForAccessibility="no"
            android:focusable="false"
            android:contentDescription="" />
    </LinearLayout>
</ScrollView>
