<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bgg21"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:paddingHorizontal="16dp">

        <Button

            style="@style/BusSceduleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="\nN.B: Sometimes the officer's bus goes as the teachers bus.\n"
            />



        <!-- Teacher Bus Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher Bus List"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/stndgreen"
                    android:paddingBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/teacherBus1"
                        style="@style/TeacherBusButton"
                        android:tag="teacher1"
                        android:text="Bus: 1 (06)"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/teacherBus2"
                        style="@style/TeacherBusButton"
                        android:tag="teacher2"
                        android:text="Bus: 2 (08)"
                        android:onClick="openLogin" />
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Officer Bus Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Officer Bus List"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/darkblue"
                    android:paddingBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/officerBus1"
                        style="@style/BlueBusButton"
                        android:tag="officer1"
                        android:text="Bus: 1 (11)"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/officerBus2"
                        style="@style/BlueBusButton"
                        android:tag="officer2"
                        android:text="Extra"
                        android:onClick="openLogin" />
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bus Schedule Button -->
        <Button
            android:id="@+id/busScheduleButton"
            style="@style/BusSceduleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bus Schedule"
            android:tag="busscedule2"
            android:onClick="openLogin" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n\n"
            android:importantForAccessibility="no"
            android:focusable="false"
            android:contentDescription="" />
    </LinearLayout>
</ScrollView>
