<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bgg21"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        android:paddingHorizontal="16dp">

        <!-- Blue Bus Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blue Bus List"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/darkblue"
                    android:paddingBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/blueBus1"
                        style="@style/BlueBusButton"
                        android:tag="blue3"
                        android:text="Bus 03"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus2"
                        style="@style/BlueBusButton"
                        android:tag="blue4"
                        android:text="Bus 04"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus3"
                        style="@style/BlueBusButton"
                        android:tag="blue5"
                        android:text="Bus 05"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus4"
                        style="@style/BlueBusButton"
                        android:tag="blue11"
                        android:text="Bus 11"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus5"
                        style="@style/BlueBusButton"
                        android:tag="blue25"
                        android:text="Bus 25"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus6"
                        style="@style/BlueBusButton"
                        android:tag="blue31"
                        android:text="Bus 31"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus7"
                        style="@style/BlueBusButton"
                        android:tag="blue32"
                        android:text="Bus 32"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus8"
                        style="@style/BlueBusButton"
                        android:tag="blue33"
                        android:text="Bus 33"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/blueBus9"
                        style="@style/BlueBusButton"
                        android:text="Extra1"
                        android:onClick="openLogin" />

                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher Bus List"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/stndgreen"
                    android:paddingBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/teacherBus1"
                        style="@style/TeacherBusButton"
                        android:tag="teacher1"
                        android:text="Bus: 1 (06)"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/teacherBus2"
                        style="@style/TeacherBusButton"
                        android:tag="teacher2"
                        android:text="Bus: 2 (08)"
                        android:onClick="openLogin" />
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Officer Bus List"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/darkblue"
                    android:paddingBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/officerBus1"
                        style="@style/BlueBusButton"
                        android:tag="officer1"
                        android:text="Bus: 1 (11)"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/officerBus2"
                        style="@style/BlueBusButton"
                        android:tag="officer2"
                        android:text="Extra"
                        android:onClick="openLogin" />
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Staff Bus Button -->
        <Button
            android:id="@+id/staffBusButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Staff Bus (14)"
            android:tag="staff1"
            android:onClick="openLogin"
            android:backgroundTint="@color/popularblue2"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="8dp"
            android:padding="16dp"
            android:elevation="6dp"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif-medium" />
        <!-- Evening Bus Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Evening Bus List"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/stndgreen"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:divider="?android:attr/dividerVertical"
                    android:showDividers="middle">

                    <Button
                        android:id="@+id/eveBus1"
                        style="@style/EveningBusButton"
                        android:tag="eve1"
                        android:onClick="openLogin"
                        android:text="Time: 7:00 PM (BUS: 25)\n\nCampus-Policeline-Eidgah" />

                    <Button
                        android:id="@+id/eveBus2"
                        style="@style/EveningBusButton"
                        android:tag="eve2"
                        android:onClick="openLogin"
                        android:text="Time: 7:30 PM (BUS: 31)\n\nPoliceline" />

                    <Button
                        android:id="@+id/eveBus3"
                        style="@style/EveningBusButton"
                        android:tag="eve3"
                        android:onClick="openLogin"
                        android:text="Time: 7:30 PM (BUS: 33)\n\nTomosmbridge" />

                    <Button
                        android:id="@+id/eveBus4"
                        style="@style/EveningBusButton"
                        android:tag="eve4"
                        android:onClick="openLogin"
                        android:text="Time: 7:30 PM (BUS: 11)\n\nDhormopur" />

                    <Button
                        android:id="@+id/eveBus5"
                        style="@style/EveningBusButton"
                        android:tag="eve5"
                        android:onClick="openLogin"
                        android:text="Time: 8:00 PM (BUS: 32)\n\nTomsombridge" />

                    <Button
                        android:id="@+id/eveBus6"
                        style="@style/EveningBusButton"
                        android:tag="eve6"
                        android:onClick="openLogin"
                        android:text="Time: 8:30 PM (BUS: 25)\n\nPoliceline" />

                    <Button
                        android:id="@+id/eveBus7"
                        style="@style/EveningBusButton"
                        android:tag="eve7"
                        android:onClick="openLogin"
                        android:text="Time: 8:30 PM (BUS: 04)\n\nTomsombridge" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Red Bus Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/offwhite2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live location of red buses will be added soon"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    android:textColor="@color/red"
                    android:paddingBottom="12dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="3"
                    android:alignmentMode="alignMargins"
                    android:useDefaultMargins="true">

                    <Button
                        android:id="@+id/redBus1"
                        style="@style/RedBusButton"
                        android:tag="red2"
                        android:text="Bus 02"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus2"
                        style="@style/RedBusButton"
                        android:tag="red3"
                        android:text="Bus 03"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus3"
                        style="@style/RedBusButton"
                        android:tag="red4"
                        android:text="Bus 04"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus4"
                        style="@style/RedBusButton"
                        android:tag="red5"
                        android:text="Bus 05"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus5"
                        style="@style/RedBusButton"
                        android:tag="red6"
                        android:text="Bus 06"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus6"
                        style="@style/RedBusButton"
                        android:tag="red7"
                        android:text="Bus 07"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus7"
                        style="@style/RedBusButton"
                        android:tag="red8"
                        android:text="Bus 08"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus8"
                        style="@style/RedBusButton"
                        android:tag="red10"
                        android:text="Bus 10"
                        android:onClick="openLogin" />

                    <Button
                        android:id="@+id/redBus9"
                        style="@style/RedBusButton"
                        android:tag="red11"
                        android:text="Extra"
                        android:onClick="openLogin" />
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bus Schedule Button -->
        <Button
            android:id="@+id/busScheduleButton"
            style="@style/BusSceduleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bus Schedule"
            android:tag="busschedule"
            android:onClick="openLogin" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="\n\n"
            android:importantForAccessibility="no"
            android:focusable="false"
            android:contentDescription="" />
    </LinearLayout>
</ScrollView>
