<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/blueloginpage3" />

    <!-- Top Right Corner Button (Smaller, Slightly Lower) -->
    <ImageButton
        android:id="@+id/driverLoginButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="40dp"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/menu2"
        android:contentDescription="Driver Login" />

    <!-- Centered Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="300dp" /> <!-- Spacer -->

        <Button
            android:layout_width="190dp"
            android:layout_height="60dp"
            android:minHeight="60dp"
            android:text="Teacher Bus List"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:tag="Teacher"
            android:onClick="openLogin"
            android:backgroundTint="@color/popularblue2"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp" />

        <Button
            android:layout_width="190dp"
            android:layout_height="60dp"
            android:minHeight="60dp"
            android:text="Student Bus List"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:tag="Student"
            android:onClick="openLogin"
            android:backgroundTint="@color/popularblue2"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp" />

    </LinearLayout>
</FrameLayout>
